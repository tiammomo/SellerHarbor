# Copy this file to .env before running docker compose.

# Frontend browser-side API URL. Keep localhost when opening the app on the host.
NEXT_PUBLIC_API_BASE_URL=http://localhost:38081/api

# Backend persistence.
REVIEWPILOT_SEED_DEMO=true
REVIEWPILOT_LLM_TIMEOUT_SECONDS=180
REVIEWPILOT_PUBLIC_API_BASE_URL=http://localhost:38081

# Local Anthropic-compatible model proxy.
# In Docker on Linux, host.docker.internal is mapped through extra_hosts.
ANTHROPIC_BASE_URL=http://host.docker.internal:17878
ANTHROPIC_AUTH_TOKEN=replace-with-your-local-token
ANTHROPIC_MODEL=mimo-v2.5-pro

# Optional infra profile: PostgreSQL.
POSTGRES_DB=reviewpilot
POSTGRES_USER=reviewpilot
POSTGRES_PASSWORD=reviewpilot
REVIEWPILOT_POSTGRES_DSN=postgresql://reviewpilot:reviewpilot@postgres:5432/reviewpilot

# Optional infra profile: Redis.
REVIEWPILOT_REDIS_URL=redis://redis:6379/0

# MinIO/S3-compatible object storage.
MINIO_ROOT_USER=reviewpilot
MINIO_ROOT_PASSWORD=reviewpilot-secret
REVIEWPILOT_OBJECT_STORAGE_ENDPOINT=http://minio:9000
REVIEWPILOT_OBJECT_STORAGE_BUCKET=reviewpilot-assets
REVIEWPILOT_OBJECT_STORAGE_REGION=us-east-1
REVIEWPILOT_OBJECT_STORAGE_ACCESS_KEY=reviewpilot
REVIEWPILOT_OBJECT_STORAGE_SECRET_KEY=reviewpilot-secret
