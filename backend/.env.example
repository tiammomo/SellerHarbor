SELLERHARBOR_PORT=38081
SELLERHARBOR_ENV=development
SELLERHARBOR_DB_PATH=data/sellerharbor.db
SELLERHARBOR_SEED_DEMO=true
SELLERHARBOR_CORS_ALLOW_ORIGINS=http://localhost:33001
SELLERHARBOR_DEFAULT_TENANT_ID=local
SELLERHARBOR_ALLOWED_TENANT_IDS=
SELLERHARBOR_DEFAULT_STORE_ID=primary-store
SELLERHARBOR_DEFAULT_STORE_NAME=SellerHarbor 默认店铺
SELLERHARBOR_DEFAULT_STORE_PLATFORM=temu
SELLERHARBOR_DEFAULT_STORE_REGION=global
SELLERHARBOR_DEFAULT_STORE_WAREHOUSE=US-West LA 3PL
SELLERHARBOR_ALLOWED_STORE_IDS=primary-store
SELLERHARBOR_MULTI_STORE_ENABLED=false
SELLERHARBOR_AUTH_REQUIRED=false
SELLERHARBOR_API_KEYS=
SELLERHARBOR_RATE_LIMIT_ENABLED=true
SELLERHARBOR_RATE_LIMIT_REQUESTS_PER_MINUTE=180
SELLERHARBOR_RATE_LIMIT_GENERATION_JOBS_PER_MINUTE=12
SELLERHARBOR_GENERATION_TASK_TIMEOUT_SECONDS=600

# If unset, the backend reads VS Code's claudeCode.environmentVariables.
ANTHROPIC_BASE_URL=http://127.0.0.1:17878
ANTHROPIC_AUTH_TOKEN=replace-with-your-local-token
ANTHROPIC_MODEL=mimo-v2.5-pro
SELLERHARBOR_LLM_TIMEOUT_SECONDS=180
SELLERHARBOR_LLM_CONNECT_TIMEOUT_SECONDS=5

# Optional when running a local MinIO/S3-compatible object store.
SELLERHARBOR_PUBLIC_API_BASE_URL=http://localhost:38081
SELLERHARBOR_OBJECT_STORAGE_ENDPOINT=http://127.0.0.1:39000
SELLERHARBOR_OBJECT_STORAGE_BUCKET=sellerharbor-assets
SELLERHARBOR_OBJECT_STORAGE_REGION=us-east-1
SELLERHARBOR_OBJECT_STORAGE_ACCESS_KEY=sellerharbor
SELLERHARBOR_OBJECT_STORAGE_SECRET_KEY=sellerharbor-secret

# Optional Temu read-only connector.
SELLERHARBOR_TEMU_API_BASE_URL=https://openapi.temu.com
SELLERHARBOR_TEMU_APP_KEY=
SELLERHARBOR_TEMU_APP_SECRET=
SELLERHARBOR_TEMU_ACCESS_TOKEN=
SELLERHARBOR_TEMU_SELLER_ID=
SELLERHARBOR_TEMU_REGION=global
SELLERHARBOR_TEMU_SANDBOX=false
