REVIEWPILOT_PORT=38081
REVIEWPILOT_DB_PATH=data/reviewpilot.db
REVIEWPILOT_SEED_DEMO=true

# If unset, the backend reads VS Code's claudeCode.environmentVariables.
ANTHROPIC_BASE_URL=http://127.0.0.1:17878
ANTHROPIC_AUTH_TOKEN=replace-with-your-local-token
ANTHROPIC_MODEL=mimo-v2.5-pro
REVIEWPILOT_LLM_TIMEOUT_SECONDS=180

# Optional when running a local MinIO/S3-compatible object store.
REVIEWPILOT_PUBLIC_API_BASE_URL=http://localhost:38081
REVIEWPILOT_OBJECT_STORAGE_ENDPOINT=http://127.0.0.1:39000
REVIEWPILOT_OBJECT_STORAGE_BUCKET=reviewpilot-assets
REVIEWPILOT_OBJECT_STORAGE_REGION=us-east-1
REVIEWPILOT_OBJECT_STORAGE_ACCESS_KEY=reviewpilot
REVIEWPILOT_OBJECT_STORAGE_SECRET_KEY=reviewpilot-secret
